FROM python:3.12-slim

WORKDIR /app

COPY stub/ ./stub/
COPY sdk/ ./sdk/

RUN pip install --no-cache-dir ./sdk ./stub

# Create restricted user
RUN useradd -m restricted

# Make /tmp read-only so the stub's _check_tmp_writable() fails
RUN chmod 555 /tmp

USER restricted

ENTRYPOINT ["python", "-m", "alchemy_stub"]
